WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://au-syd.ml.cloud.ibm.com
# Generation model — verified available models (au-syd, 2025):
#   meta-llama/llama-3-3-70b-instruct   (recommended)
#   ibm/granite-8b-code-instruct
#   ibm/granite-guardian-3-8b
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct
# Embedding model — verified available models (au-syd, 2025):
#   intfloat/multilingual-e5-large      (1024-dim, supports Indian languages — recommended)
#   ibm/slate-125m-english-rtrvr-v2
#   ibm/slate-30m-english-rtrvr-v2
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-large
VECTOR_DB_PROVIDER=chroma
MILVUS_HOST=localhost
MILVUS_PORT=19530
FLASK_ENV=development
FLASK_DEBUG=1
USE_MOCK=false
