WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://au-syd.ml.cloud.ibm.com
# Generation model — IBM Granite, verified on au-syd project (2025):
#   ibm/granite-8b-code-instruct  ← used (only callable IBM Granite on this account)
#   ibm/granite-guardian-3-8b     ← safety/guardian variant, not for general Q&A
# System prompts override code-style output with explicit natural-language instruction.
GRANITE_MODEL_ID=ibm/granite-8b-code-instruct
# Embedding model — IBM Slate, verified on au-syd project (2025):
#   ibm/slate-125m-english-rtrvr-v2  ← used (768-dim)
#   ibm/slate-30m-english-rtrvr-v2   ← lighter alternative (384-dim)
EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr-v2
VECTOR_DB_PROVIDER=chroma
MILVUS_HOST=localhost
MILVUS_PORT=19530
FLASK_ENV=development
FLASK_DEBUG=1
USE_MOCK=false
